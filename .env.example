# --- Meta Graph API ---
# Long-lived user access token from your Meta Developer App.
# Required scopes: ads_read (and optionally business_management).
# Generate one at https://developers.facebook.com → your app → Tools → Get Token.
META_ACCESS_TOKEN=

# Graph API version. Tested with v22.0. Older versions get sunset on a rolling
# schedule, so prefer to keep this current.
META_API_VERSION=v22.0

# --- Authentication ---
# Bearer token clients must send in `Authorization: Bearer <token>` to call /mcp.
# v0.1 single-tenant: any client with this token can read your Meta ad data.
# Generate with: openssl rand -hex 32
AUTH_TOKEN=

# --- Server ---
# Public URL of this deployment. Currently only used in log lines; v0.2 will
# use it for OAuth callback URLs.
PUBLIC_URL=https://connector.example.com

# Port to listen on. Bind behind a reverse proxy (nginx/Caddy) that terminates TLS.
PORT=3210

# debug | info | warn | error
LOG_LEVEL=info
